# Copy to .env.local and fill in from your Supabase project
# Supabase Dashboard > Project Settings > API

# Public (safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SECRET — server only. Never expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (for the AI CV assessment feature)
ANTHROPIC_API_KEY=

# Resend (optional — candidate status + new-account emails). If unset, email is
# skipped and applications/stage changes/account creation still work normally.
RESEND_API_KEY=
RESEND_FROM="WilsTracker <onboarding@resend.dev>"

# Base URL used for links/buttons inside emails. Defaults to the production URL.
NEXT_PUBLIC_APP_URL=
